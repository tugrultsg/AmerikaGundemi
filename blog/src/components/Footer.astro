---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <p>&copy; {year} Amerika Gündemi</p>
    <p class="disclaimer">
      Bu site, ABD'deki podcast ve haber içeriklerinin yapay zeka destekli Türkçe çevirilerini sunmaktadır.
      Orijinal içerikler ilgili YouTube kanallarına aittir.
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    margin-top: 3rem;
    padding: 2rem 1.5rem;
    text-align: center;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .footer p {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .disclaimer {
    margin-top: 0.5rem;
    font-size: 0.75rem !important;
  }
</style>
