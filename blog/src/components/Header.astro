---
const navItems = [
  { href: '/', label: 'Ana Sayfa' },
  { href: '/arsiv', label: 'Arşiv' },
  { href: '/sozluk', label: 'Sözlük' },
  { href: '/hakkinda', label: 'Hakkında' },
];
---

<header class="header">
  <div class="header-inner">
    <a href="/" class="logo">
      <span class="logo-gundem">GÜNDEM</span><span class="logo-amerika">AMERİKA</span>
    </a>
    <nav class="nav-desktop">
      {navItems.map(({ href, label }) => (
        <a href={href} class="nav-link">{label}</a>
      ))}
      <a href="/rss.xml" class="nav-rss" aria-label="RSS">RSS</a>
    </nav>
    <button class="nav-toggle" id="nav-toggle" aria-label="Menü">
      <span></span><span></span><span></span>
    </button>
  </div>
  <nav class="nav-mobile" id="nav-mobile">
    {navItems.map(({ href, label }) => (
      <a href={href} class="nav-mobile-link">{label}</a>
    ))}
    <a href="/rss.xml" class="nav-mobile-link">RSS</a>
  </nav>
</header>

<script is:inline>
  document.getElementById('nav-toggle').addEventListener('click', function() {
    document.getElementById('nav-mobile').classList.toggle('open');
    this.classList.toggle('open');
  });
</script>

<style>
  .header {
    background: var(--color-dark);
    color: white;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-family: var(--font-sans);
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: white;
    display: flex;
    gap: 0.3rem;
    align-items: baseline;
  }

  .logo:hover { color: white; text-decoration: none; }

  .logo-gundem {
    color: var(--color-accent);
  }

  .logo-amerika {
    color: white;
  }

  .nav-desktop {
    display: flex;
    gap: 1.75rem;
    align-items: center;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: #d1d5db;
    letter-spacing: 0.01em;
  }

  .nav-link:hover { color: white; text-decoration: none; }

  .nav-rss {
    font-size: 0.75rem;
    font-weight: 600;
    color: #9ca3af;
    padding: 0.2rem 0.6rem;
    border: 1px solid #374151;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .nav-rss:hover { color: white; border-color: #6b7280; text-decoration: none; }

  /* Mobile nav */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle span {
    display: block;
    width: 20px;
    height: 2px;
    background: white;
    transition: transform 0.2s, opacity 0.2s;
  }

  .nav-toggle.open span:nth-child(1) { transform: rotate(45deg) translate(4px, 4px); }
  .nav-toggle.open span:nth-child(2) { opacity: 0; }
  .nav-toggle.open span:nth-child(3) { transform: rotate(-45deg) translate(4px, -4px); }

  .nav-mobile {
    display: none;
    background: var(--color-dark);
    border-top: 1px solid #374151;
    padding: 0.5rem 1.5rem 1rem;
  }

  .nav-mobile.open { display: block; }

  .nav-mobile-link {
    display: block;
    padding: 0.6rem 0;
    color: #d1d5db;
    font-size: 0.95rem;
    font-weight: 500;
    border-bottom: 1px solid #1f2937;
  }

  .nav-mobile-link:hover { color: white; text-decoration: none; }

  @media (max-width: 640px) {
    .nav-desktop { display: none; }
    .nav-toggle { display: flex; }
  }
</style>
