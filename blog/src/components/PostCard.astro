---
interface Props {
  title: string;
  date: Date;
  description: string;
  channel: string;
  videoId: string;
  tags: string[];
  slug: string;
  readingTime: { summary: number; full: number };
  featured?: boolean;
}

const { title, date, description, channel, videoId, tags, slug, readingTime, featured = false } = Astro.props;
const thumbnail = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;
const formattedDate = date.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' });
---

<article class:list={['post-card', { featured }]}>
  <a href={`/yazilar/${slug}`} class="card-link">
    <div class="card-image">
      <img src={thumbnail} alt={title} loading="lazy" width="480" height="360" />
      <div class="card-image-overlay"></div>
      <span class="card-channel">{channel}</span>
      <span class="card-reading">{readingTime.summary} dk</span>
    </div>
    <div class="card-body">
      <div class="card-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
      <h2 class="card-title">{title}</h2>
      <p class="card-description">{description}</p>
      <div class="card-footer">
        <div class="card-tags">
          {tags.slice(0, 3).map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
        <span class="ai-badge" title="Bu içerik Claude AI kullanılarak çevrilmiştir">AI Çeviri</span>
      </div>
    </div>
  </a>
</article>

<style>
  .post-card {
    background: var(--color-surface);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.25s, transform 0.25s;
    border: 1px solid var(--color-border);
  }

  .post-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }

  .card-link {
    color: inherit;
    text-decoration: none;
    display: block;
    height: 100%;
  }

  .card-image {
    position: relative;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .post-card:hover .card-image img {
    transform: scale(1.05);
  }

  .card-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 50%);
    pointer-events: none;
  }

  .card-channel {
    position: absolute;
    top: 10px;
    left: 10px;
    background: var(--color-accent);
    color: white;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .card-reading {
    position: absolute;
    bottom: 10px;
    right: 10px;
    background: rgba(0,0,0,0.7);
    color: white;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }

  .card-body {
    padding: 1rem 1.25rem 1.25rem;
  }

  .card-meta {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 0.4rem;
    font-weight: 500;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-description {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .ai-badge {
    font-family: var(--font-sans);
    font-size: 0.55rem;
    font-weight: 700;
    padding: 0.15rem 0.45rem;
    background: #ede9fe;
    color: #6d28d9;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    cursor: help;
  }

  .tag {
    font-size: 0.6rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    background: var(--color-tag-bg);
    color: var(--color-text-secondary);
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* Featured variant */
  .featured {
    border: none;
    box-shadow: var(--shadow-md);
  }

  .featured .card-image img {
    height: 340px;
  }

  .featured .card-title {
    font-size: 1.5rem;
    -webkit-line-clamp: 4;
  }

  .featured .card-description {
    font-size: 0.95rem;
    -webkit-line-clamp: 3;
  }

  @media (max-width: 640px) {
    .card-image img {
      height: 180px;
    }

    .featured .card-image img {
      height: 200px;
    }

    .featured .card-title {
      font-size: 1.2rem;
    }

    .card-body {
      padding: 0.85rem 1rem 1rem;
    }

    .card-title {
      font-size: 0.95rem;
    }
  }
</style>
