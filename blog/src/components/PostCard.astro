---
interface Props {
  title: string;
  date: Date;
  description: string;
  channel: string;
  videoId: string;
  tags: string[];
  slug: string;
  readingTime: { summary: number; full: number };
  featured?: boolean;
}

const { title, date, description, channel, videoId, tags, slug, readingTime, featured = false } = Astro.props;
const thumbnail = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;
const formattedDate = date.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' });
---

<article class:list={['post-card', { featured }]}>
  <a href={`/yazilar/${slug}`} class="card-link">
    <div class="card-image">
      <img src={thumbnail} alt={title} loading="lazy" width="480" height="360" />
      <span class="card-channel">{channel}</span>
    </div>
    <div class="card-body">
      <div class="card-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span class="dot">&middot;</span>
        <span>{readingTime.summary} dk okuma</span>
      </div>
      <h2 class="card-title">{title}</h2>
      <p class="card-description">{description}</p>
      <div class="card-tags">
        {tags.slice(0, 3).map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </div>
  </a>
</article>

<style>
  .post-card {
    background: var(--color-surface);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .post-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .card-link {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  .card-image {
    position: relative;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .post-card:hover .card-image img {
    transform: scale(1.03);
  }

  .card-channel {
    position: absolute;
    bottom: 8px;
    left: 8px;
    background: rgba(0,0,0,0.75);
    color: white;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 0.02em;
  }

  .card-body {
    padding: 1rem 1.25rem 1.25rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .dot { font-size: 0.5rem; }

  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.35;
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-description {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }

  .card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    background: var(--color-tag-bg);
    color: var(--color-text-secondary);
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* Featured variant */
  .featured .card-image img {
    height: 320px;
  }

  .featured .card-title {
    font-size: 1.5rem;
    -webkit-line-clamp: 4;
  }

  .featured .card-description {
    font-size: 0.95rem;
    -webkit-line-clamp: 3;
  }

  @media (max-width: 640px) {
    .featured .card-image img {
      height: 220px;
    }
    .featured .card-title {
      font-size: 1.2rem;
    }
  }
</style>
