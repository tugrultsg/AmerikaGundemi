---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostMeta from '../components/PostMeta.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SourceAttribution from '../components/SourceAttribution.astro';
import RelatedPosts from '../components/RelatedPosts.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  allPosts: CollectionEntry<'posts'>[];
  summaryHtml: string;
  fullTranslationHtml: string;
}

const { post, allPosts, summaryHtml, fullTranslationHtml } = Astro.props;
const { title, date, source, channel, videoId, description, tags, guests, readingTime } = post.data;
const thumbnail = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: thumbnail,
  datePublished: date.toISOString(),
  author: {
    '@type': 'Organization',
    name: 'Amerika Gündemi',
    url: 'https://gundemamerika.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Amerika Gündemi',
    url: 'https://gundemamerika.com',
  },
};
---

<BaseLayout
  title={title}
  description={description}
  ogImage={thumbnail}
  ogType="article"
  canonicalUrl={`https://gundemamerika.com/yazilar/${post.id}`}
  jsonLd={jsonLd}
>
  <Header />

  <!-- Hero image -->
  <div class="post-hero">
    <img src={thumbnail} alt={title} />
    <div class="post-hero-overlay"></div>
    <div class="post-hero-content">
      <a href={`/kanal/${channel.toLowerCase().replace(/\s+/g, '-')}`} class="hero-channel">{channel}</a>
      <h1>{title}</h1>
    </div>
  </div>

  <main class="post-page">
    <Breadcrumbs crumbs={[
      { label: channel, href: `/kanal/${channel.toLowerCase().replace(/\s+/g, '-')}` },
      { label: title },
    ]} />

    <article>
      <PostMeta
        channel={channel}
        date={date}
        guests={guests}
        tags={tags}
        readingTime={readingTime}
      />

      <!-- Source link -->
      <a href={source} target="_blank" rel="noopener noreferrer" class="source-link">
        Orijinal videoyu izle &rarr;
      </a>

      {fullTranslationHtml && (
        <div class="content-tabs">
          <button class="tab active" data-tab="summary">
            <span class="tab-label">Özet Makale</span>
            <span class="tab-time">{readingTime.summary} dk okuma</span>
          </button>
          <button class="tab" data-tab="full">
            <span class="tab-label">Tam Çeviri</span>
            <span class="tab-time">{readingTime.full} dk okuma</span>
          </button>
        </div>
      )}

      <section class="tab-content active" id="tab-summary" set:html={summaryHtml} />

      {fullTranslationHtml && (
        <section class="tab-content" id="tab-full" set:html={fullTranslationHtml} />
      )}

      <SourceAttribution source={source} channel={channel} />
    </article>

    <RelatedPosts currentId={post.id} tags={tags} allPosts={allPosts} />
  </main>
  <Footer />
</BaseLayout>

<script is:inline>
  document.querySelectorAll('.content-tabs .tab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = this.getAttribute('data-tab');
      // Toggle active tab button
      document.querySelectorAll('.content-tabs .tab').forEach(function(b) { b.classList.remove('active'); });
      this.classList.add('active');
      // Toggle content
      document.querySelectorAll('.tab-content').forEach(function(c) { c.classList.remove('active'); });
      document.getElementById('tab-' + tab).classList.add('active');
      // Scroll to top of content
      document.querySelector('.content-tabs').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>

<style>
  /* Hero image */
  .post-hero {
    position: relative;
    width: 100%;
    height: 400px;
    overflow: hidden;
  }

  .post-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 40%, transparent 70%);
  }

  .post-hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .hero-channel {
    display: inline-block;
    background: var(--color-accent);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.25rem 0.7rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
    text-decoration: none;
  }

  .hero-channel:hover {
    background: var(--color-accent-hover);
    color: white;
    text-decoration: none;
  }

  .post-hero-content h1 {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    font-weight: 700;
    line-height: 1.2;
    color: white;
    text-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }

  /* Page body */
  .post-page {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 1.5rem 1.5rem 2rem;
  }

  .source-link {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--color-accent);
    border-radius: 5px;
    margin-bottom: 1.5rem;
    transition: all 0.15s;
  }

  .source-link:hover {
    background: var(--color-accent);
    color: white;
    text-decoration: none;
  }

  /* Tabs */
  .content-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 2rem;
    border-bottom: 2px solid var(--color-border);
    position: sticky;
    top: 60px;
    background: var(--color-bg);
    z-index: 10;
    padding-top: 0.5rem;
  }

  .tab {
    font-family: var(--font-sans);
    padding: 0.75rem 1.25rem;
    border: none;
    background: none;
    color: var(--color-text-muted);
    cursor: pointer;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    transition: color 0.15s, border-color 0.15s;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1rem;
  }

  .tab-label {
    font-size: 0.9rem;
    font-weight: 700;
  }

  .tab-time {
    font-size: 0.7rem;
    font-weight: 400;
    opacity: 0.6;
  }

  .tab:hover {
    color: var(--color-text);
  }

  .tab.active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  /* Tab content */
  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  /* Article typography */
  .tab-content :global(h2) {
    font-family: var(--font-sans);
    font-size: 1.3rem;
    font-weight: 700;
    margin: 2.5rem 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-accent);
    display: inline-block;
  }

  .tab-content :global(h2 + p),
  .tab-content :global(h2 + *) {
    display: block;
  }

  .tab-content :global(p) {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.85;
    margin-bottom: 1.25rem;
    color: var(--color-text);
  }

  .tab-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: var(--color-accent-light);
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  .tab-content :global(blockquote p) {
    color: var(--color-text-secondary);
    font-style: italic;
    margin-bottom: 0;
    font-size: 1rem;
  }

  /* Speaker labels in full translation */
  #tab-full :global(p > strong:first-child) {
    font-family: var(--font-sans);
    display: inline-block;
    background: var(--color-dark);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.15rem 0.6rem;
    border-radius: 3px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-right: 0.4rem;
    vertical-align: middle;
  }

  #tab-full :global(p:has(> strong:first-child)) {
    padding-left: 1rem;
    border-left: 3px solid var(--color-border);
    margin-bottom: 1rem;
    padding-top: 0.25rem;
  }

  @media (max-width: 640px) {
    .post-hero {
      height: 280px;
    }

    .post-hero-content h1 {
      font-size: 1.5rem;
    }

    .tab-content :global(p) {
      font-size: 1rem;
      line-height: 1.75;
    }
  }
</style>
