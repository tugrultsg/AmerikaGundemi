---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostMeta from '../components/PostMeta.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SourceAttribution from '../components/SourceAttribution.astro';
import RelatedPosts from '../components/RelatedPosts.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  allPosts: CollectionEntry<'posts'>[];
  summaryHtml: string;
  fullTranslationHtml: string;
}

const { post, allPosts, summaryHtml, fullTranslationHtml } = Astro.props;
const { title, date, source, channel, videoId, description, tags, guests, readingTime } = post.data;
const thumbnail = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: thumbnail,
  datePublished: date.toISOString(),
  author: {
    '@type': 'Organization',
    name: 'Amerika Gündemi',
    url: 'https://gundemamerika.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Amerika Gündemi',
    url: 'https://gundemamerika.com',
  },
};
---

<BaseLayout
  title={title}
  description={description}
  ogImage={thumbnail}
  ogType="article"
  canonicalUrl={`https://gundemamerika.com/yazilar/${post.id}`}
  jsonLd={jsonLd}
>
  <Header />
  <main class="post-page">
    <Breadcrumbs crumbs={[
      { label: channel, href: `/kanal/${channel.toLowerCase().replace(/\s+/g, '-')}` },
      { label: title },
    ]} />

    <article>
      <h1>{title}</h1>
      <PostMeta
        channel={channel}
        date={date}
        guests={guests}
        tags={tags}
        readingTime={readingTime}
      />

      {fullTranslationHtml && (
        <div class="content-tabs">
          <button class="tab active" data-tab="summary">Özet Makale <span class="tab-time">{readingTime.summary} dk</span></button>
          <button class="tab" data-tab="full">Tam Çeviri <span class="tab-time">{readingTime.full} dk</span></button>
        </div>
      )}

      <section class="tab-content active" id="tab-summary" set:html={summaryHtml} />

      {fullTranslationHtml && (
        <section class="tab-content" id="tab-full" set:html={fullTranslationHtml} />
      )}

      <SourceAttribution source={source} channel={channel} />
    </article>

    <RelatedPosts currentId={post.id} tags={tags} allPosts={allPosts} />
  </main>
  <Footer />
</BaseLayout>

<script is:inline>
  document.querySelectorAll('.content-tabs .tab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = this.getAttribute('data-tab');
      // Toggle active tab button
      document.querySelectorAll('.content-tabs .tab').forEach(function(b) { b.classList.remove('active'); });
      this.classList.add('active');
      // Toggle content
      document.querySelectorAll('.tab-content').forEach(function(c) { c.classList.remove('active'); });
      document.getElementById('tab-' + tab).classList.add('active');
      // Scroll to top of content
      document.querySelector('.content-tabs').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>

<style>
  .post-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  article h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  /* Tabs */
  .content-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 2rem;
    border-bottom: 2px solid var(--color-border);
    position: sticky;
    top: 0;
    background: var(--color-bg);
    z-index: 10;
    padding-top: 0.5rem;
  }

  .tab {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.75rem 1.25rem;
    border: none;
    background: none;
    color: var(--color-text-muted);
    cursor: pointer;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    transition: color 0.15s, border-color 0.15s;
  }

  .tab:hover {
    color: var(--color-text);
  }

  .tab.active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .tab-time {
    font-weight: 400;
    font-size: 0.8rem;
    opacity: 0.7;
  }

  /* Tab content */
  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  /* Summary styles */
  #tab-summary :global(h2) {
    font-size: 1.35rem;
    margin: 2rem 0 0.75rem;
  }

  #tab-summary :global(p) {
    margin-bottom: 1rem;
  }

  #tab-summary :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 1rem 0;
  }

  /* Full translation styles */
  #tab-full :global(h2) {
    font-size: 1.25rem;
    margin: 1.5rem 0 0.75rem;
  }

  #tab-full :global(p) {
    margin-bottom: 1rem;
  }

  #tab-full :global(blockquote) {
    border-left: 3px solid var(--color-border);
    padding-left: 1rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 1rem 0;
  }

  /* Speaker labels — **Name:** rendered as <strong>Name:</strong> by markdown */
  #tab-full :global(p > strong:first-child) {
    font-family: var(--font-heading);
    color: var(--color-accent);
    font-size: 0.9rem;
    letter-spacing: 0.01em;
  }

  /* Alternate speaker colors for readability */
  #tab-full :global(p:has(> strong:first-child)) {
    padding-left: 0.75rem;
    border-left: 3px solid transparent;
    margin-bottom: 0.75rem;
  }
</style>
