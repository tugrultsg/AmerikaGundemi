---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostMeta from '../components/PostMeta.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SourceAttribution from '../components/SourceAttribution.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  allPosts: CollectionEntry<'posts'>[];
  summaryHtml: string;
  fullTranslationHtml: string;
}

const { post, allPosts, summaryHtml: rawSummaryHtml, fullTranslationHtml: rawFullHtml } = Astro.props;
const { title, date, source, channel, videoId, description, tags, guests, readingTime } = post.data;
const thumbnail = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;

// Add IDs to h2 headings for ToC anchor links
function addHeadingIds(html: string): string {
  return html.replace(/<h2>([^<]+)<\/h2>/gi, (_match, text) => {
    const id = text.trim().toLowerCase()
      .replace(/[^a-zçğıöşü0-9\s-]/g, '')
      .replace(/\s+/g, '-')
      .slice(0, 60);
    return `<h2 id="${id}">${text}</h2>`;
  });
}

const summaryHtml = addHeadingIds(rawSummaryHtml);
const fullTranslationHtml = rawFullHtml ? addHeadingIds(rawFullHtml) : '';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: thumbnail,
  datePublished: date.toISOString(),
  author: {
    '@type': 'Organization',
    name: 'Amerika Gündemi',
    url: 'https://gundemamerika.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Amerika Gündemi',
    url: 'https://gundemamerika.com',
  },
};
---

<BaseLayout
  title={title}
  description={description}
  ogImage={thumbnail}
  ogType="article"
  canonicalUrl={`https://gundemamerika.com/yazilar/${post.id}`}
  jsonLd={jsonLd}
>
  <Header />

  <!-- Reading progress bar (#5) -->
  <div class="progress-container"><div class="progress-bar" id="reading-progress"></div></div>

  <main class="post-page">
    <Breadcrumbs crumbs={[
      { label: channel, href: `/kanal/${channel.toLowerCase().replace(/\s+/g, '-')}` },
      { label: title },
    ]} />

    <article>
      <a href={`/kanal/${channel.toLowerCase().replace(/\s+/g, '-')}`} class="hero-channel">{channel}</a>
      <h1>{title}</h1>

      <PostMeta
        channel={channel}
        date={date}
        guests={guests}
        tags={tags}
        readingTime={readingTime}
      />

      <!-- YouTube embed -->
      <div class="video-embed">
        <iframe
          src={`https://www.youtube.com/embed/${videoId}`}
          title={title}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>

      <!-- Table of Contents (#6) -->
      <TableOfContents html={summaryHtml} />

      <!-- Share buttons (#2) -->
      <div class="share-bar">
        <span class="share-label">Paylaş:</span>
        <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(`https://gundemamerika.com/yazilar/${post.id}`)}`} target="_blank" rel="noopener noreferrer" class="share-btn share-x">X</a>
        <a href={`https://api.whatsapp.com/send?text=${encodeURIComponent(title + ' ' + `https://gundemamerika.com/yazilar/${post.id}`)}`} target="_blank" rel="noopener noreferrer" class="share-btn share-wa">WhatsApp</a>
        <a href={`https://t.me/share/url?url=${encodeURIComponent(`https://gundemamerika.com/yazilar/${post.id}`)}&text=${encodeURIComponent(title)}`} target="_blank" rel="noopener noreferrer" class="share-btn share-tg">Telegram</a>
        <button type="button" id="copy-link-btn" class="share-btn share-copy">Link Kopyala</button>
      </div>

      {fullTranslationHtml && (
        <div class="content-tabs">
          <button class="tab active" data-tab="summary">
            <span class="tab-label">Özet Makale</span>
            <span class="tab-time">{readingTime.summary} dk okuma</span>
          </button>
          <button class="tab" data-tab="full">
            <span class="tab-label">Tam Çeviri</span>
            <span class="tab-time">{readingTime.full} dk okuma</span>
          </button>
        </div>
      )}

      <section class="tab-content active" id="tab-summary" set:html={summaryHtml} />

      {fullTranslationHtml && (
        <section class="tab-content" id="tab-full" set:html={fullTranslationHtml} />
      )}

      <SourceAttribution source={source} channel={channel} />

      <!-- Feedback + Support -->
      <div class="support-cta">
        <p>Bu çeviriyi faydalı buldunuz mu?</p>
        <div class="feedback-row" data-video-id={videoId}>
          <button type="button" class="feedback-btn" data-vote="up">&#128077; Evet</button>
          <button type="button" class="feedback-btn" data-vote="down">&#128078; Hayır</button>
        </div>
        <div class="feedback-result" style="display:none"></div>
        <a href="https://buymeacoffee.com/gundemamerika" target="_blank" rel="noopener noreferrer" class="support-btn">Destek Ol</a>
      </div>
    </article>

    <RelatedPosts currentId={post.id} tags={tags} allPosts={allPosts} />
  </main>
  <Footer />
</BaseLayout>

<script is:inline>
  // Tab switching
  document.querySelectorAll('.content-tabs .tab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = this.getAttribute('data-tab');
      document.querySelectorAll('.content-tabs .tab').forEach(function(b) { b.classList.remove('active'); });
      this.classList.add('active');
      document.querySelectorAll('.tab-content').forEach(function(c) { c.classList.remove('active'); });
      document.getElementById('tab-' + tab).classList.add('active');
      document.querySelector('.content-tabs').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // Reading progress bar (#5)
  var progressBar = document.getElementById('reading-progress');
  if (progressBar) {
    window.addEventListener('scroll', function() {
      var h = document.documentElement;
      var scrollTop = h.scrollTop || document.body.scrollTop;
      var scrollHeight = h.scrollHeight - h.clientHeight;
      var progress = (scrollTop / scrollHeight) * 100;
      progressBar.style.width = progress + '%';
    });
  }

  // Feedback (#18)
  document.querySelectorAll('.feedback-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var row = this.closest('.feedback-row');
      var videoId = row.getAttribute('data-video-id');
      var vote = this.getAttribute('data-vote');
      var resultDiv = row.parentElement.querySelector('.feedback-result');

      fetch('/api/feedback', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ videoId: videoId, vote: vote }),
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        row.style.display = 'none';
        resultDiv.style.display = 'block';
        resultDiv.textContent = 'Teşekkürler! (' + data.counts.up + ' olumlu, ' + data.counts.down + ' olumsuz)';
      })
      .catch(function() {
        resultDiv.style.display = 'block';
        resultDiv.textContent = 'Geri bildiriminiz kaydedildi, teşekkürler!';
        row.style.display = 'none';
      });
    });
  });

  // Share: copy link (#2)
  var copyBtn = document.getElementById('copy-link-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', function() {
      navigator.clipboard.writeText(window.location.href).then(function() {
        copyBtn.textContent = 'Kopyalandı!';
        setTimeout(function() { copyBtn.textContent = 'Link Kopyala'; }, 2000);
      });
    });
  }
</script>

<style>
  /* Reading progress bar */
  .progress-container {
    position: fixed;
    top: 60px;
    left: 0;
    width: 100%;
    height: 3px;
    background: transparent;
    z-index: 99;
  }

  .progress-bar {
    height: 100%;
    width: 0%;
    background: var(--color-accent);
    transition: width 0.1s;
  }

  /* Page body */
  .post-page {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 1.5rem 1.5rem 2rem;
  }

  /* Channel badge */
  .hero-channel {
    display: inline-block;
    background: var(--color-accent);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.25rem 0.7rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
    text-decoration: none;
  }

  .hero-channel:hover {
    background: var(--color-accent-hover);
    color: white;
    text-decoration: none;
  }

  article h1 {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  /* YouTube embed */
  .video-embed {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
    overflow: hidden;
    border-radius: var(--radius);
    margin-bottom: 1.5rem;
    background: #000;
  }

  .video-embed iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* Share buttons */
  .share-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .share-label {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .share-btn {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.35rem 0.75rem;
    border-radius: 5px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-secondary);
    cursor: pointer;
    text-decoration: none;
    transition: all 0.15s;
  }

  .share-btn:hover {
    background: var(--color-dark);
    color: white;
    border-color: var(--color-dark);
    text-decoration: none;
  }

  .share-x:hover { background: #000; border-color: #000; }
  .share-wa:hover { background: #25D366; border-color: #25D366; }
  .share-tg:hover { background: #0088cc; border-color: #0088cc; }

  /* Support CTA */
  .support-cta {
    text-align: center;
    padding: 2rem;
    margin-top: 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .support-cta p {
    font-family: var(--font-sans) !important;
    font-size: 0.95rem !important;
    font-weight: 600;
    color: var(--color-text-secondary);
    margin-bottom: 0.75rem;
  }

  .support-btn {
    display: inline-block;
    background: #FFDD00;
    color: #000;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.6rem 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .support-btn:hover {
    background: #FFE84D;
    color: #000;
    text-decoration: none;
  }

  .feedback-row {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .feedback-btn {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-surface);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.15s;
  }

  .feedback-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .feedback-result {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  /* Tabs */
  .content-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 2rem;
    border-bottom: 2px solid var(--color-border);
    position: sticky;
    top: 60px;
    background: var(--color-bg);
    z-index: 10;
    padding-top: 0.5rem;
  }

  .tab {
    font-family: var(--font-sans);
    padding: 0.75rem 1.25rem;
    border: none;
    background: none;
    color: var(--color-text-muted);
    cursor: pointer;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    transition: color 0.15s, border-color 0.15s;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1rem;
  }

  .tab-label {
    font-size: 0.9rem;
    font-weight: 700;
  }

  .tab-time {
    font-size: 0.7rem;
    font-weight: 400;
    opacity: 0.6;
  }

  .tab:hover {
    color: var(--color-text);
  }

  .tab.active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  /* Tab content */
  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  /* Article typography */
  .tab-content :global(h2) {
    font-family: var(--font-sans);
    font-size: 1.3rem;
    font-weight: 700;
    margin: 2.5rem 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-accent);
    display: inline-block;
  }

  .tab-content :global(h2 + p),
  .tab-content :global(h2 + *) {
    display: block;
  }

  .tab-content :global(p) {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.85;
    margin-bottom: 1.25rem;
    color: var(--color-text);
  }

  .tab-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: var(--color-accent-light);
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  .tab-content :global(blockquote p) {
    color: var(--color-text-secondary);
    font-style: italic;
    margin-bottom: 0;
    font-size: 1rem;
  }

  /* Speaker labels in full translation */
  #tab-full :global(p > strong:first-child) {
    font-family: var(--font-sans);
    display: inline-block;
    background: var(--color-dark);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.15rem 0.6rem;
    border-radius: 3px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-right: 0.4rem;
    vertical-align: middle;
  }

  #tab-full :global(p:has(> strong:first-child)) {
    padding-left: 1rem;
    border-left: 3px solid var(--color-border);
    margin-bottom: 1rem;
    padding-top: 0.25rem;
  }

  @media (max-width: 640px) {
    article h1 {
      font-size: 1.5rem;
    }

    .tab {
      flex: 1;
      text-align: center;
      align-items: center;
      padding: 0.6rem 0.5rem;
    }

    .tab-label {
      font-size: 0.8rem;
    }

    .tab-content :global(p) {
      font-size: 1rem;
      line-height: 1.75;
    }

    .share-bar {
      gap: 0.35rem;
    }

    .share-btn {
      flex: 1;
      text-align: center;
      min-height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .share-label {
      display: none;
    }

    #tab-full :global(p > strong:first-child) {
      font-size: 0.6rem;
    }
  }
</style>
