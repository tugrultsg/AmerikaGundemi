---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import SearchBar from '../components/SearchBar.astro';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const channels = [...new Set(posts.map(p => p.data.channel))];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Gündem Amerika',
  url: 'https://gundemamerika.com',
  description: 'ABD podcast ve haber içeriklerinin Türkçe çevirileri',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://gundemamerika.com/arsiv?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};

const featuredPost = posts[0];
const otherPosts = posts.slice(1);
---

<BaseLayout title="Gündem Amerika" jsonLd={jsonLd}>
  <Header />
  <main>
    {posts.length === 0 ? (
      <div class="container">
        <p class="empty">Henüz yazı eklenmedi. Yakında ABD gündemine dair içerikler burada olacak.</p>
      </div>
    ) : (
      <>
        {/* Featured post */}
        <section class="hero-section">
          <div class="container">
            <PostCard
              title={featuredPost.data.title}
              date={featuredPost.data.date}
              description={featuredPost.data.description}
              channel={featuredPost.data.channel}
              videoId={featuredPost.data.videoId}
              tags={featuredPost.data.tags}
              slug={featuredPost.id}
              readingTime={featuredPost.data.readingTime}
              featured={true}
            />
          </div>
        </section>

        {/* Channel filter bar */}
        {channels.length > 1 && (
          <section class="channels-bar">
            <div class="container">
              <div class="channels-scroll">
                {channels.map((ch) => (
                  <a href={`/kanal/${ch.toLowerCase().replace(/\s+/g, '-')}`} class="channel-chip">{ch}</a>
                ))}
              </div>
            </div>
          </section>
        )}

        {/* Search */}
        <div class="container search-section">
          <SearchBar />
        </div>

        {/* All other posts */}
        {otherPosts.length > 0 && (
          <section class="posts-section">
            <div class="container">
              <h2 class="section-title">Son Çeviriler</h2>
              <div class="posts-grid">
                {otherPosts.map((post) => (
                  <PostCard
                    title={post.data.title}
                    date={post.data.date}
                    description={post.data.description}
                    channel={post.data.channel}
                    videoId={post.data.videoId}
                    tags={post.data.tags}
                    slug={post.id}
                    readingTime={post.data.readingTime}
                  />
                ))}
              </div>
            </div>
          </section>
        )}

        {posts.length > 12 && (
          <div class="container see-all">
            <a href="/arsiv" class="see-all-link">Tüm yazıları gör &rarr;</a>
          </div>
        )}
      </>
    )}
  </main>
  <Footer />
</BaseLayout>

<style>
  .search-section {
    padding-top: 1rem;
    padding-bottom: 0.5rem;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero-section {
    padding: 2rem 0 1rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 1.25rem;
  }

  .hero-sidebar {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .sidebar-item {
    display: flex;
    gap: 0.75rem;
    padding: 0.75rem;
    background: var(--color-surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    color: inherit;
    text-decoration: none;
    transition: box-shadow 0.2s;
  }

  .sidebar-item:hover {
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }

  .sidebar-item img {
    width: 120px;
    height: 80px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
  }

  .sidebar-text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .sidebar-channel {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .sidebar-text h3 {
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Channel chips */
  .channels-bar {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .channels-scroll {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0.25rem 0;
  }

  .channels-scroll::-webkit-scrollbar { display: none; }

  .channel-chip {
    flex-shrink: 0;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.4rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    color: var(--color-text-secondary);
    white-space: nowrap;
    transition: all 0.15s;
  }

  .channel-chip:hover {
    background: var(--color-dark);
    color: white;
    border-color: var(--color-dark);
    text-decoration: none;
  }

  /* Posts grid */
  .posts-section {
    padding: 2rem 0;
  }

  .section-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-dark);
    display: inline-block;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .see-all {
    text-align: center;
    padding: 2rem 0;
  }

  .see-all-link {
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.6rem 1.5rem;
    border: 2px solid var(--color-accent);
    border-radius: 6px;
    transition: all 0.15s;
  }

  .see-all-link:hover {
    background: var(--color-accent);
    color: white;
    text-decoration: none;
  }

  .empty {
    text-align: center;
    color: var(--color-text-muted);
    margin: 4rem 0;
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-sidebar {
      flex-direction: row;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      gap: 0.75rem;
      padding-bottom: 0.5rem;
    }

    .sidebar-item {
      flex-shrink: 0;
      width: 280px;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
