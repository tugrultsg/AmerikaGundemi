---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import { channelSlug } from '../../lib/slugs';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const channelPages = new Map<string, { channel: string; posts: typeof posts }>();

  for (const post of posts) {
    const slug = channelSlug(post.data.channel);
    const page = channelPages.get(slug) ?? { channel: post.data.channel, posts: [] };

    if (!page.posts.some((p) => p.id === post.id)) {
      page.posts.push(post);
    }

    channelPages.set(slug, page);
  }

  return [...channelPages.entries()].map(([slug, page]) => ({
    params: { channel: slug },
    props: {
      channel: page.channel,
      posts: page.posts
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { channel, posts } = Astro.props;
---

<BaseLayout title={`${channel} Çevirileri`} description={`${channel} kanalından çevrilmiş yazılar`}>
  <Header />
  <main class="channel-page">
    <h1>{channel}</h1>
    <p class="count">{posts.length} yazı</p>

    <div class="posts-grid">
      {posts.map((post: any) => (
        <PostCard
          title={post.data.title}
          date={post.data.date}
          description={post.data.description}
          channel={post.data.channel}
          videoId={post.data.videoId}
          tags={post.data.tags}
          slug={post.id}
          readingTime={post.data.readingTime}
        />
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .channel-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  h1 { font-size: 1.8rem; margin-bottom: 0.25rem; }
  .count { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 1.5rem; }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
</style>
