---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const guestMap = new Map<string, string>(); // slug -> original name

  for (const p of posts) {
    for (const guest of p.data.guests) {
      const slug = guest.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
      if (!guestMap.has(slug)) guestMap.set(slug, guest);
    }
  }

  return [...guestMap.entries()].map(([slug, name]) => ({
    params: { guest: slug },
    props: {
      guestName: name,
      posts: posts
        .filter((p) => p.data.guests.includes(name))
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { guestName, posts } = Astro.props;
---

<BaseLayout title={`${guestName}`} description={`${guestName} ile ilgili yazılar`}>
  <Header />
  <main class="guest-page">
    <h1>{guestName}</h1>
    <p class="count">{posts.length} yazı</p>

    <div class="posts-grid">
      {posts.map((post: any) => (
        <PostCard
          title={post.data.title}
          date={post.data.date}
          description={post.data.description}
          channel={post.data.channel}
          videoId={post.data.videoId}
          tags={post.data.tags}
          slug={post.id}
          readingTime={post.data.readingTime}
        />
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .guest-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  h1 { font-size: 1.8rem; margin-bottom: 0.25rem; }
  .count { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 1.5rem; }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
</style>
